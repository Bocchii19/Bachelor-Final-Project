# ============================================================
# CV Attendance System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cv_attendance

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Camera PTZ ---
PTZ_HOST=your_camera_ip
PTZ_PORT=80
PTZ_USER=your_camera_username
PTZ_PASSWORD=your_camera_password
PTZ_RTSP_URL=rtsp://user:pass@your_camera_ip/stream1

# --- CV Models (paths to model weights) ---
# InsightFace will auto-download models if not found
INSIGHTFACE_MODEL_PACK=buffalo_l
LIVENESS_MODEL_PATH=./models/anti_spoof_model.onnx

# --- Thresholds ---
CONFIDENCE_AUTO_PRESENT=0.75
CONFIDENCE_SUGGEST=0.45
COVERAGE_TARGET=0.90

# --- ONNX Runtime ---
# Execution provider priority: TensorrtExecutionProvider, CUDAExecutionProvider, CPUExecutionProvider
# Leave empty for auto-detection
ONNX_PROVIDERS=

# --- Storage ---
MEDIA_ROOT=./media
# S3 (optional):
# S3_BUCKET=cv-attendance-media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

# --- Auth ---
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# --- App ---
DEBUG=true
APP_NAME=CV Attendance System
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
